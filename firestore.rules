rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBootstrappedAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'paulmoumita248@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrappedAdmin() || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role']) &&
             data.keys().size() >= 3 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['customer', 'admin'];
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'date', 'time', 'guests', 'areaId', 'status']) &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.size() <= 20 &&
             data.time is string && data.time.size() <= 10 &&
             data.guests is number && data.guests > 0 && data.guests <= 50 &&
             data.areaId is string &&
             data.status in ['pending', 'confirmed', 'cancelled', 'rejected'];
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) &&
                    (isAdmin() || incoming().role == existing().role || isBootstrappedAdmin());
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100) && (
        isAdmin() || resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          isOwner(existing().userId) && 
          incoming().userId == existing().userId &&
          incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'guests', 'areaId', 'areaName', 'notes', 'status', 'isArchived', 'updatedAt']) &&
          (existing().status == 'pending' || incoming().status == 'cancelled' || incoming().isArchived == true) 
        )
      );
      allow delete: if isAdmin();
    }

    match /seatingAreas/{areaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
